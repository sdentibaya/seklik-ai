datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

model Subject {
  id                   String                @id @default(uuid())
  name                 String                @unique
  description          String?
  capaianPembelajarans CapaianPembelajaran[]
}

model Phase {
  id                   String                @id @default(uuid())
  name                 String                @unique // "A", "B", "C"
  description          String?
  classes              String // e.g., "Kelas 1-2"
  capaianPembelajarans CapaianPembelajaran[]
}

model CapaianPembelajaran {
  id        String @id @default(uuid())
  subjectId String
  phaseId   String
  content   String // Teks CP utama secara keseluruhan

  subject  Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  phase    Phase       @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  elements CPElement[]

  @@unique([subjectId, phaseId])
}

model CPElement {
  id                    String @id @default(uuid())
  capaianPembelajaranId String
  name                  String // Nama elemen (e.g. "Bilangan", "Aljabar")
  content               String // Deskripsi/isi CP untuk elemen tersebut

  capaianPembelajaran CapaianPembelajaran @relation(fields: [capaianPembelajaranId], references: [id], onDelete: Cascade)
}

model ClassSetup {
  id        String   @id @default("active-setup")
  subjectId String
  phaseId   String
  updatedAt DateTime @updatedAt
}

model TujuanPembelajaran {
  id          String   @id @default(uuid())
  subjectId   String
  phaseId     String
  code        String // e.g., "TP-01"
  element     String // e.g., "Bilangan"
  description String // Isi teks TP
  order       Int // Urutan dalam ATP
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([subjectId, phaseId, code])
}
